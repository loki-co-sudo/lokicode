{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "lokicode",
  "mainBinaryName": "lokicode",
  "version": "0.56.0",
  "identifier": "com.herok.lokicode",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "lokicode",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/loki-co-sudo/lokicode/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEIwQ0U3NUM0MEQ2MDJDRkUKUldUK0xHQU54SFhPc0dQNEt0aGtDdXFKU0prcmhRYnMyaFVlWUpESXZJT1orUUJic3A2bEhYVysK"
    }
  }
}
