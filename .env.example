# OpenRouter API configuration
# Copy this file to ".env" and fill in your real values, then restart the dev server.
# Get a key at https://openrouter.ai/keys

# Required: your OpenRouter API key.
VITE_OPENROUTER_API_KEY=sk-or-your-key-here

# Optional: model id to use (defaults to anthropic/claude-3.5-sonnet).
# See https://openrouter.ai/models for available ids.
VITE_OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
