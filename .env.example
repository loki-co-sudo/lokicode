# OpenRouter API configuration (read by the Rust backend — NOT exposed to the frontend).
# Copy this file to ".env" and fill in your real values, then restart `npm run tauri dev`.
# Get a key at https://openrouter.ai/keys
#
# In the packaged (double-click) app there is no .env, so set the key from the
# in-app Settings dialog instead — it is stored in the OS app-config directory.

# Required: your OpenRouter API key.
OPENROUTER_API_KEY=sk-or-your-key-here

# Optional: model id to use (defaults to anthropic/claude-sonnet-4.6).
# See https://openrouter.ai/models for available ids.
OPENROUTER_MODEL=anthropic/claude-sonnet-4.6
